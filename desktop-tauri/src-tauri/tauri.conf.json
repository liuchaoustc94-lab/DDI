{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DDI Risk Assessment",
  "version": "0.1.0",
  "identifier": "com.everestmedicines.ddi.desktop",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/invoke-local-node.ps1 ./scripts/run-app-script.cjs dev -- --host 127.0.0.1 --port 4174",
    "devUrl": "http://127.0.0.1:4174",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/invoke-local-node.ps1 ./scripts/run-app-script.cjs build",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "DDI Risk Assessment",
        "width": 1600,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
